#!/usr/bin/env bash
set -euo pipefail

:<<'comment'
  src

  Manage source repositories under ~/src/<host>/<owner>/<repo>.

  Subcommands:
    clone <URL>           Clone a repo into $SRC_ROOT/<host>/<owner>/<repo>. The
                          destination path is printed on stdout on success so
                          callers can `cd "$(src clone <URL>)"`. If <URL> points
                          at a GitHub user/org (no repo segment), clone every
                          public, non-archived, non-fork repo they own.
    sync git [PATH]       Walk $SRC_ROOT (or PATH, if given) and fast-forward each git repo
                          to its default branch, stashing/restoring any uncommitted work
                          around the update. If PATH points directly at a git repo, only
                          that repo is updated.
    sync import <VOLUME>  Rsync source from /Volumes/<VOLUME>/russelltsherman/src into $SRC_ROOT.
comment

SRC_ROOT="${SRC_ROOT:-$HOME/src}"

usage() {
  cat <<EOF 1>&2
Usage: $(basename "$0") <command> [args...]

Commands:
  clone [-j N] <URL>             Clone <URL> into \$SRC_ROOT/<host>/<owner>/<repo>.
                                 Bulk-clones a GitHub user/org's public source
                                 repos when <URL> has no repo segment.
  sync git [-j N] [PATH]         Fast-forward every git repo under \$SRC_ROOT (or PATH)
  sync import <VOLUME> [--dry-run]
                                 Rsync /Volumes/<VOLUME>/russelltsherman/src into \$SRC_ROOT
  help                           Show this help

Environment:
  SRC_ROOT         Base directory for repos (default: \$HOME/src)
  SRC_SYNC_JOBS    Default parallelism for 'sync git' and bulk 'clone' (default: 8)
EOF
  exit "${1:-1}"
}

sync_usage() {
  cat <<EOF 1>&2
Usage: $(basename "$0") sync <subcommand> [args...]

Subcommands:
  git [-j N] [PATH]              Fast-forward every git repo under \$SRC_ROOT (or PATH)
  import <VOLUME> [--dry-run]    Rsync /Volumes/<VOLUME>/russelltsherman/src into \$SRC_ROOT
EOF
  exit "${1:-1}"
}

require() {
  for cmd in "$@"; do
    command -v "$cmd" >/dev/null || { echo "required command not found: $cmd" 1>&2; exit 1; }
  done
}

_parse_clone_url() {
  # Parse a git clone URL and emit "host\towner\trepo" on stdout.
  # Supports HTTPS and SCP-style SSH URLs:
  #   https://[user[:pass]@]host[:port]/owner/.../repo[.git][/]
  #   git@host:owner/.../repo[.git][/]
  # "owner" may contain '/' to accommodate nested groups (e.g. GitLab subgroups).
  local url="$1"
  local host="" path=""

  if [[ "$url" == https://* ]]; then
    local rest="${url#https://}"
    rest="${rest%/}"
    rest="${rest#*@}"             # strip optional user[:pass]@
    if [[ "$rest" != */* ]]; then
      echo "URL has no path: $url" 1>&2; return 1
    fi
    host="${rest%%/*}"
    path="${rest#*/}"
  elif [[ "$url" == git@*:* ]]; then
    local rest="${url#git@}"
    host="${rest%%:*}"
    path="${rest#*:}"
  else
    echo "unsupported URL format: $url" 1>&2
    echo "expected https://host/owner/repo[.git] or git@host:owner/repo[.git]" 1>&2
    return 1
  fi

  path="${path%/}"
  path="${path%.git}"

  [ -n "$host" ] || { echo "could not parse host from URL: $url" 1>&2; return 1; }
  [ -n "$path" ] || { echo "could not parse path from URL: $url" 1>&2; return 1; }

  local repo="${path##*/}"
  local owner="${path%/*}"
  # No '/' in path means we have a repo but no owner.
  if [ "$owner" = "$path" ]; then
    echo "URL is missing an owner segment: $url" 1>&2; return 1
  fi
  [ -n "$repo" ]  || { echo "could not parse repo from URL: $url"  1>&2; return 1; }
  [ -n "$owner" ] || { echo "could not parse owner from URL: $url" 1>&2; return 1; }

  printf '%s\t%s\t%s\n' "$host" "$owner" "$repo"
}

_extract_bulk_owner() {
  # If $1 is a github.com URL pointing at just a user or org (no repo segment),
  # emit the owner name on stdout. Otherwise emit nothing. Used by cmd_clone to
  # decide between single-repo and bulk-org clone modes before falling through
  # to _parse_clone_url (which errors on missing-owner URLs).
  local url="$1"
  local host="" path=""

  if [[ "$url" == https://* ]]; then
    local rest="${url#https://}"
    rest="${rest%/}"
    rest="${rest#*@}"
    host="${rest%%/*}"
    [ "$host" = "$rest" ] && return 0
    path="${rest#*/}"
  elif [[ "$url" == git@*:* ]]; then
    local rest="${url#git@}"
    host="${rest%%:*}"
    path="${rest#*:}"
  else
    return 0
  fi

  [ "$host" = "github.com" ] || return 0
  path="${path%/}"
  path="${path%.git}"
  [ -n "$path" ] || return 0
  [[ "$path" != */* ]] || return 0

  printf '%s' "$path"
}

_clone_worker() {
  # xargs worker: clone one repo described by "owner/name<TAB>cloneUrl".
  local record="$1"
  local name url
  IFS=$'\t' read -r name url <<< "$record"
  [ -n "$name" ] || { echo "empty clone record" 1>&2; return 1; }
  [ -n "$url" ]  || { echo "missing clone url for '$name'" 1>&2; return 1; }

  local owner="${name%%/*}"
  local repo="${name##*/}"
  local dest="$SRC_ROOT/github.com/$owner/$repo"

  local out rc=0
  out=$(
    if [ -e "$dest" ]; then
      echo "    destination already exists: $dest"
    else
      mkdir -p "$(dirname "$dest")"
      echo "    cloning $url -> $dest"
      git clone "$url" "$dest" 2>&1
    fi
  ) || rc=$?

  if [ "$rc" -ne 0 ]; then
    if [ -n "${SRC_CLONE_FAIL_DIR:-}" ]; then
      local reason
      reason="$(printf '%s\n' "$out" | tail -n 1 | sed 's/^[[:space:]]*//')"
      [ -z "$reason" ] && reason="(see output above)"
      printf '%s\t%s\n' "$name" "$reason" > "$(mktemp "$SRC_CLONE_FAIL_DIR/fail.XXXXXX")"
    fi
    out="${out}"$'\n'"    clone failed: $name"
  fi

  if [ -n "${SRC_CLONE_LOCK_DIR:-}" ]; then
    while ! mkdir "$SRC_CLONE_LOCK_DIR/lock" 2>/dev/null; do :; done
    printf '==> %s\n%s\n' "$name" "$out" 1>&2
    rmdir "$SRC_CLONE_LOCK_DIR/lock"
  else
    printf '==> %s\n%s\n' "$name" "$out" 1>&2
  fi
  return "$rc"
}

_clone_github_owner() {
  # Bulk-clone every public, non-archived, non-fork repo owned by $1 on github.com.
  # All progress and errors go to stderr; stdout is silent.
  local owner="$1"
  local jobs="$2"
  require gh

  local work_dir
  work_dir="$(mktemp -d)"
  # shellcheck disable=SC2064
  trap "rm -rf '$work_dir'" EXIT

  local stderr_file="$work_dir/gh-stderr"
  echo "listing public source repos for github.com/$owner" 1>&2
  local repos_tsv
  if ! repos_tsv=$(gh repo list "$owner" \
      --visibility public \
      --no-archived \
      --source \
      --limit 4000 \
      --json nameWithOwner,sshUrl \
      --jq '.[] | [.nameWithOwner, .sshUrl] | @tsv' 2>"$stderr_file"); then
    echo "gh repo list failed for '$owner':" 1>&2
    cat "$stderr_file" 1>&2
    exit 1
  fi

  if [ -z "$repos_tsv" ]; then
    echo "no public, non-archived, non-fork repos found for github.com/$owner" 1>&2
    return 0
  fi

  local count
  count=$(printf '%s\n' "$repos_tsv" | wc -l | tr -d ' ')
  echo "cloning $count repos under github.com/$owner (jobs=$jobs)" 1>&2

  export SRC_ROOT
  export SRC_CLONE_FAIL_DIR="$work_dir"
  export SRC_CLONE_LOCK_DIR="$work_dir"

  printf '%s\n' "$repos_tsv" \
    | tr '\n' '\0' \
    | xargs -0 -P "$jobs" -n 1 "$BASH" "${BASH_SOURCE[0]}" _clone-worker \
    || true

  local errors
  errors=$(find "$work_dir" -maxdepth 1 -type f -name 'fail.*' | wc -l | tr -d ' ')

  echo 1>&2
  if [ "$errors" -gt 0 ]; then
    echo "Failures ($errors):" 1>&2
    while IFS= read -r -d '' f; do
      local name reason
      IFS=$'\t' read -r name reason < "$f"
      printf '  %s\n      %s\n' "$name" "$reason" 1>&2
    done < <(find "$work_dir" -maxdepth 1 -type f -name 'fail.*' -print0)
    echo 1>&2
    echo "done — $count repos, $errors error(s)" 1>&2
    exit 1
  fi
  echo "done — $count repos" 1>&2
}

cmd_clone() {
  require git

  local url=""
  local jobs="${SRC_SYNC_JOBS:-8}"
  while [ $# -gt 0 ]; do
    case "$1" in
      -j|--jobs) jobs="${2:?-j requires a number}"; shift ;;
      -h|--help)
        cat <<EOF
Usage: $(basename "$0") clone [-j N] <URL>

Clone a git repository into \$SRC_ROOT/<host>/<owner>/<repo>, creating the
intermediate host/owner directories as needed.

Single-repo mode (default):
  When <URL> points at a repo, the absolute destination path is printed on
  stdout so it can be captured:

      cd "\$(src clone https://github.com/owner/repo)"

  Supported URL formats:
    HTTPS:  https://host/owner/repo[.git]
    SSH:    git@host:owner/repo[.git]

  If the destination directory already exists, prints a warning to stderr,
  skips the clone, and still prints the destination path on stdout (exit 0).
  This makes the command idempotent: capturing the output with \$(...) works
  whether or not the repo was already present.

Bulk mode (GitHub user/org):
  When <URL> points at a GitHub user or org with no repo segment, e.g.
      https://github.com/<owner>      or      git@github.com:<owner>
  clones every public, non-archived, non-fork repo owned by <owner> into
  \$SRC_ROOT/github.com/<owner>/<repo>. Existing destinations are skipped
  individually (not treated as errors). Stdout is silent; progress, per-repo
  output, and the failure summary are written to stderr. Exits non-zero if
  any repo failed to clone.

  Requires the 'gh' CLI to be installed and authenticated against github.com.

Options:
  -j, --jobs N     Parallelism for bulk mode (default: \$SRC_SYNC_JOBS or 8).
                   Ignored in single-repo mode.
EOF
        exit 0
        ;;
      --) shift; break ;;
      -*) echo "unknown option: $1" 1>&2; exit 1 ;;
      *)
        if [ -z "$url" ]; then
          url="$1"
        else
          echo "unexpected argument: $1" 1>&2; exit 1
        fi
        ;;
    esac
    shift
  done

  [ -n "$url" ] || { echo "missing required argument: URL" 1>&2; exit 1; }

  case "$jobs" in
    ''|*[!0-9]*|0) echo "invalid --jobs value: $jobs" 1>&2; exit 1 ;;
  esac

  local bulk_owner
  bulk_owner="$(_extract_bulk_owner "$url")"
  if [ -n "$bulk_owner" ]; then
    _clone_github_owner "$bulk_owner" "$jobs"
    return
  fi

  local host owner repo parsed
  parsed="$(_parse_clone_url "$url")" || exit 1
  IFS=$'\t' read -r host owner repo <<< "$parsed"

  local dest="$SRC_ROOT/$host/$owner/$repo"

  if [ -e "$dest" ]; then
    echo "destination already exists: $dest" 1>&2
  else
    mkdir -p "$(dirname "$dest")"
    echo "cloning $url -> $dest" 1>&2
    git clone "$url" "$dest" 1>&2
  fi
  printf '%s\n' "$dest"
}

_update_repo() {
  # Update one git repo: stash dirty work, fast-forward the default branch,
  # restore the original branch, and reapply the stash.
  local dir="$1"
  (
    cd "$dir"

    git remote get-url origin >/dev/null 2>&1 || { echo "    no 'origin' remote — skipping"; exit 0; }

    # Determine the default branch from origin/HEAD; ask the remote if not cached.
    local default_branch
    default_branch="$(git symbolic-ref --quiet --short refs/remotes/origin/HEAD 2>/dev/null | sed 's@^origin/@@')" || true
    if [ -z "$default_branch" ]; then
      git remote set-head origin --auto >/dev/null 2>&1 || true
      default_branch="$(git symbolic-ref --quiet --short refs/remotes/origin/HEAD 2>/dev/null | sed 's@^origin/@@')" || true
    fi
    [ -n "$default_branch" ] || { echo "    could not determine default branch — skipping" 1>&2; exit 1; }

    local current
    current="$(git symbolic-ref --quiet --short HEAD || true)"
    if [ -z "$current" ]; then
      echo "    detached HEAD — fetching only"
      git fetch --prune origin
      exit 0
    fi

    # Stash anything in the working tree (tracked + untracked).
    local stashed=0
    if ! git diff --quiet \
       || ! git diff --cached --quiet \
       || [ -n "$(git ls-files --others --exclude-standard)" ]; then
      echo "    stashing local changes on '$current'"
      git stash push --include-untracked --message "src-sync $(date -u +%Y%m%dT%H%M%SZ)" >/dev/null
      stashed=1
    fi

    # Restore branch + stash; used on both the success and failure paths.
    restore() {
      if [ "$current" != "$default_branch" ]; then
        echo "    checkout $default_branch -> $current"
        git checkout --quiet "$current" 2>/dev/null || { echo "    warning: could not return to '$current'" 1>&2; return 1; }
      fi
      if [ "$stashed" -eq 1 ]; then
        echo "    reapplying stash"
        if ! git stash pop --quiet; then
          echo "    stash pop conflicted — left as stash@{0} for you to resolve" 1>&2
          return 1
        fi
      fi
    }

    if [ "$current" != "$default_branch" ]; then
      echo "    checkout $current -> $default_branch"
      if ! git checkout --quiet "$default_branch"; then
        echo "    checkout '$default_branch' failed" 1>&2
        restore || true
        exit 1
      fi
    fi

    git fetch --prune origin
    if ! git merge --ff-only "origin/$default_branch"; then
      echo "    '$default_branch' not fast-forwardable — leaving as-is" 1>&2
      restore || true
      exit 1
    fi

    restore
  )
}

_sync_git_worker() {
  # Worker entry point invoked once per repo by xargs -P. Captures all output
  # from _update_repo so the per-repo block prints as one contiguous chunk,
  # guarded by a coarse mkdir-based lock since printf to a tty flushes per
  # newline and would otherwise interleave with other workers.
  local dir="$1"
  local rel="${dir#"$SRC_ROOT"/}"
  local out rc=0
  out="$(_update_repo "$dir" 2>&1)" || rc=$?

  if [ "$rc" -ne 0 ]; then
    if [ -n "${SRC_SYNC_FAIL_DIR:-}" ]; then
      # Record rel<TAB>reason so the parent can surface a summary at the end.
      # Pull the last indented status line out of the captured output as the reason.
      local reason
      reason="$(printf '%s\n' "$out" | grep -E '^    [^ ]' | tail -n 1 | sed 's/^    //')"
      [ -z "$reason" ] && reason="(see output above)"
      printf '%s\t%s\n' "$rel" "$reason" > "$(mktemp "$SRC_SYNC_FAIL_DIR/fail.XXXXXX")"
    fi
    out="${out}"$'\n'"    update failed: $rel"
  fi

  if [ -n "${SRC_SYNC_LOCK_DIR:-}" ]; then
    while ! mkdir "$SRC_SYNC_LOCK_DIR/lock" 2>/dev/null; do :; done
    printf '==> %s\n%s\n' "$rel" "$out"
    rmdir "$SRC_SYNC_LOCK_DIR/lock"
  else
    printf '==> %s\n%s\n' "$rel" "$out"
  fi
  return "$rc"
}

cmd_sync_git() {
  require git find xargs

  local jobs="${SRC_SYNC_JOBS:-8}"
  local scope=""
  while [ $# -gt 0 ]; do
    case "$1" in
      -j|--jobs) jobs="${2:?-j requires a number}"; shift ;;
      -h|--help)
        cat <<EOF
Usage: $(basename "$0") sync git [-j N] [PATH]

Walks \$SRC_ROOT (or PATH, if given) and fast-forwards each git repo to its
default branch. Dirty working trees are stashed before the update and
reapplied after. If PATH points directly at a git repo (a directory
containing a .git/), only that repo is updated.

Arguments:
  PATH           Directory to scope the walk to. Resolved relative to the
                 current working directory. Default: \$SRC_ROOT.

Options:
  -j, --jobs N   Run N updates in parallel (default: \$SRC_SYNC_JOBS or 8)
EOF
        exit 0
        ;;
      --) shift; break ;;
      -*) echo "unknown option: $1" 1>&2; exit 1 ;;
      *)
        if [ -z "$scope" ]; then
          scope="$1"
        else
          echo "unexpected argument: $1" 1>&2; exit 1
        fi
        ;;
    esac
    shift
  done

  case "$jobs" in
    ''|*[!0-9]*|0) echo "invalid --jobs value: $jobs" 1>&2; exit 1 ;;
  esac

  local search_root
  if [ -n "$scope" ]; then
    [ -d "$scope" ] || { echo "no such directory: $scope" 1>&2; exit 1; }
    search_root="$(cd "$scope" && pwd -P)"
  else
    [ -d "$SRC_ROOT" ] || { echo "no source dir: $SRC_ROOT" 1>&2; exit 1; }
    search_root="$SRC_ROOT"
  fi

  echo "updating git repos under $search_root (jobs=$jobs)"

  local repos=()
  if [ -d "$search_root/.git" ]; then
    repos+=("$search_root")
  else
    while IFS= read -r -d '' git_dir; do
      repos+=("${git_dir%/.git}")
    done < <(find "$search_root" -mindepth 1 -maxdepth 8 -type d -name .git -prune -print0 2>/dev/null)
  fi

  local count=${#repos[@]}
  echo "found $count repos"
  [ "$count" -gt 0 ] || { echo "done"; return 0; }

  local fail_dir
  fail_dir="$(mktemp -d)"
  # shellcheck disable=SC2064
  trap "rm -rf '$fail_dir'" EXIT

  export SRC_ROOT
  export SRC_SYNC_FAIL_DIR="$fail_dir"
  export SRC_SYNC_LOCK_DIR="$fail_dir"

  # Re-invoke this script per repo so the worker has _update_repo in scope.
  # Use $BASH explicitly so we don't depend on the file's exec bit.
  printf '%s\0' "${repos[@]}" \
    | xargs -0 -P "$jobs" -n 1 "$BASH" "${BASH_SOURCE[0]}" _sync-git-worker \
    || true

  local errors
  errors=$(find "$fail_dir" -type f -name 'fail.*' | wc -l | tr -d ' ')

  echo
  if [ "$errors" -gt 0 ]; then
    echo "Failures ($errors):"
    while IFS= read -r -d '' f; do
      local rel reason
      IFS=$'\t' read -r rel reason < "$f"
      printf '  %s\n      %s\n' "$rel" "$reason"
    done < <(find "$fail_dir" -type f -name 'fail.*' -print0)
    echo
    echo "done — $count repos, $errors error(s)"
    exit 1
  fi
  echo "done — $count repos"
}

cmd_sync_import() {
  require rsync

  local volume=""
  local dest="$SRC_ROOT"
  local dry_run=0

  while [ $# -gt 0 ]; do
    case "$1" in
      -n|--dry-run) dry_run=1 ;;
      -h|--help)
        cat <<EOF
Usage: $(basename "$0") sync import <VOLUME> [--dry-run]

Safely rsync source repositories from an external volume into \$SRC_ROOT.

Arguments:
  VOLUME          Name of the mounted volume under /Volumes
                  (source path is /Volumes/<VOLUME>/russelltsherman/src)

Options:
  -n, --dry-run   Preview the changes without copying anything.

Safety:
  - Never deletes files on the destination.
  - Skips files that are newer on the destination (--update).
  - Excludes .DS_Store and stale git lock files.

Example:
  $(basename "$0") sync import REDBAR0 --dry-run   # preview
  $(basename "$0") sync import REDBAR0             # perform the sync
EOF
        exit 0
        ;;
      --) shift; break ;;
      -*) echo "unknown option: $1" 1>&2; exit 1 ;;
      *)
        if [ -z "$volume" ]; then
          volume="$1"
        else
          echo "unexpected argument: $1" 1>&2; exit 1
        fi
        ;;
    esac
    shift
  done

  [ -n "$volume" ] || { echo "missing required argument: VOLUME" 1>&2; exit 1; }

  local source="/Volumes/$volume/russelltsherman/src"
  [ -d "$source" ] || { echo "source not found (is '$volume' mounted?): $source" 1>&2; exit 1; }
  mkdir -p "$dest"

  local -a flags=(
    --archive
    --human-readable
    --itemize-changes
    --update
    --exclude=.DS_Store
    --exclude=.git/index.lock
    --exclude=.git/HEAD.lock
    --exclude=.git/*.lock
  )

  if [ "$dry_run" -eq 1 ]; then
    flags+=(--dry-run)
    echo "DRY RUN: $source/ -> $dest/"
  else
    echo "syncing $source/ -> $dest/"
  fi
  echo

  rsync "${flags[@]}" "$source/" "$dest/"
}

cmd_sync() {
  [ $# -ge 1 ] || sync_usage
  local subcmd="$1"; shift
  case "$subcmd" in
    git)            cmd_sync_git "$@" ;;
    import)         cmd_sync_import "$@" ;;
    help|-h|--help) sync_usage 0 ;;
    *)              echo "unknown sync subcommand: $subcmd" 1>&2; sync_usage ;;
  esac
}

main() {
  [ $# -ge 1 ] || usage
  local subcmd="$1"; shift
  case "$subcmd" in
    clone)             cmd_clone "$@" ;;
    sync)              cmd_sync "$@" ;;
    _sync-git-worker)  _sync_git_worker "$@" ;;  # internal, used by xargs fan-out
    _clone-worker)     _clone_worker "$@" ;;     # internal, used by xargs fan-out
    help|-h|--help)    usage 0 ;;
    *)                 echo "unknown command: $subcmd" 1>&2; usage ;;
  esac
}

main "$@"
