#!/usr/bin/env bash
set -euo pipefail

readonly SOURCE="/Users/russelltsherman"
readonly DESTS=("REDBAR0" "REDBAR1")
readonly VOLUMES_ROOT="/Volumes"

readonly RSYNC_FLAGS=(-avh)
readonly RSYNC_FILTERS=(
  --include='/.config'
  --include='/.data'
  --exclude='/.*'
  --exclude='Applications'
  --exclude='Library'
  --exclude='node_modules'
)

log() { echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*" >&2; }
die() { log "ERROR: $*"; exit 1; }

check_root() {
  [[ $EUID -eq 0 ]] || die "This script must be run with root privileges (use sudo)."
}

check_mount() {
  local name="$1"
  local path="${VOLUMES_ROOT}/${name}"
  [[ -d "$path" ]] || die "Backup volume not mounted: $path"
  [[ -w "$path" ]] || die "Backup volume not writable: $path"
}

# rsync exit codes 23/24 = partial transfer / files vanished — treat as warnings.
backup_to() {
  local name="$1"
  local dest="${VOLUMES_ROOT}/${name}"
  local rc=0

  log "Starting backup to ${dest}"
  rsync "${RSYNC_FLAGS[@]}" "${RSYNC_FILTERS[@]}" "$SOURCE" "$dest" || rc=$?

  case "$rc" in
    0)        log "Backup to ${dest} completed cleanly." ;;
    23 | 24)  log "Backup to ${dest} completed with warnings (rsync exit ${rc}); continuing." ;;
    *)        die "Backup to ${dest} failed (rsync exit ${rc})." ;;
  esac
}

main() {
  check_root

  local d
  for d in "${DESTS[@]}"; do
    check_mount "$d"
  done

  for d in "${DESTS[@]}"; do
    backup_to "$d"
  done

  log "All backups finished."
}

main "$@"
